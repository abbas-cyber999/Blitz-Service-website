NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Use the Supabase pooled connection string for development and schema sync.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Optional direct connection reference for manual diagnostics only. Prisma's default Lingoria workflow does not read it.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/postgres"
LINGORIA_DEMO_USER_ID="demo-learner"
