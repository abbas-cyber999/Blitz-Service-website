generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum LessonType {
  LESSON
  GRAMMAR
}

enum LessonBlockType {
  SCENE
  EXPLANATION
  PHRASES
  TIP
  DIALOGUE
  SUMMARY
  QUIZ
  WRITING
}

enum UserLessonStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ImportJobType {
  LESSONS
  GRAMMAR
  PLACEMENT
}

enum ImportJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               UserRole            @default(USER)
  nativeLanguageCode String?
  targetLanguageCode String              @default("de")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  accounts         Account[]
  sessions         Session[]
  lessonProgress   UserLessonProgress[]
  exerciseAttempts ExerciseAttempt[]
  dailyActivities  DailyActivity[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Course {
  id                 String    @id @default(cuid())
  slug               String    @unique
  code               String    @unique
  title              String
  description        String?
  targetLanguageCode String
  nativeLanguageCode String
  cefrLevel          String
  published          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  units          Unit[]
  placementTests PlacementTest[]
}

model Unit {
  id          String    @id @default(cuid())
  courseId    String
  slug        String
  title       String
  description String?
  orderIndex  Int
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@unique([courseId, slug])
  @@unique([courseId, orderIndex])
}

model Lesson {
  id               String      @id @default(cuid())
  unitId           String
  slug             String      @unique
  legacySourceFile String?
  legacySourceId   String?
  titleNative      String
  titleGerman      String
  description      String?
  orderIndex       Int
  lessonType       LessonType
  cefrLevel        String
  published        Boolean     @default(false)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  unit      Unit                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  blocks    LessonBlock[]
  exercises Exercise[]
  attempts  ExerciseAttempt[]
  progress  UserLessonProgress[]

  @@unique([unitId, orderIndex])
  @@index([unitId, lessonType])
}

model LessonBlock {
  id          String          @id @default(cuid())
  lessonId    String
  blockType   LessonBlockType
  orderIndex  Int
  title       String?
  contentJson Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@unique([lessonId, orderIndex])
  @@index([lessonId, blockType])
}

model Exercise {
  id            String       @id @default(cuid())
  lessonId      String
  lessonBlockId String?
  type          String
  prompt        String
  promptGerman  String?
  explanation   String?
  hint          String?
  orderIndex    Int
  contentJson   Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonBlock LessonBlock? @relation(fields: [lessonBlockId], references: [id], onDelete: SetNull)
  attempts    ExerciseAttempt[]

  @@index([lessonId])
  @@index([lessonBlockId])
}

model PlacementTest {
  id                 String    @id @default(cuid())
  courseId           String?
  languageCode       String
  targetLanguageCode String
  title              String
  published          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  course    Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)
  questions PlacementQuestion[]
}

model PlacementQuestion {
  id              String   @id @default(cuid())
  placementTestId String
  legacySourceId  String?
  cefrLevel       String
  prompt          String
  orderIndex      Int
  contentJson     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  placementTest PlacementTest @relation(fields: [placementTestId], references: [id], onDelete: Cascade)

  @@unique([placementTestId, orderIndex])
}

model UserLessonProgress {
  id             String           @id @default(cuid())
  userId         String
  lessonId       String
  status         UserLessonStatus @default(NOT_STARTED)
  startedAt      DateTime?
  completedAt    DateTime?
  score          Float?
  attemptsCount  Int              @default(0)
  lastBlockIndex Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model ExerciseAttempt {
  id              String   @id @default(cuid())
  userId          String
  exerciseId      String
  lessonId        String
  isCorrect       Boolean
  submittedAnswer Json
  score           Float?
  createdAt       DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
}

model DailyActivity {
  id                 String   @id @default(cuid())
  userId             String
  activityDate       DateTime
  lessonsCompleted   Int      @default(0)
  exercisesCompleted Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
}

model ImportJob {
  id          String          @id @default(cuid())
  type        ImportJobType
  sourcePath  String
  status      ImportJobStatus @default(PENDING)
  summaryJson Json?
  createdAt   DateTime        @default(now())
  completedAt DateTime?
}
