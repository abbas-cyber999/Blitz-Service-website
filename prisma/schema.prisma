generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id              String        @id @default(cuid())
  name            String
  email           String
  phone           String
  subject         String
  service         String
  message         String        @db.Text
  privacyAccepted Boolean
  status          MessageStatus @default(NEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Language {
  id              String         @id @default(cuid())
  code            String         @unique
  name            String
  nativeName      String
  direction       LanguageDirection
  locale          String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  sourcePairs     LanguagePair[] @relation("SourceLanguage")
  targetPairs     LanguagePair[] @relation("TargetLanguage")
  vocabularyItems VocabularyItem[]
  grammarNotes    GrammarNote[]
  scenarios       Scenario[]

  @@map("languages")
}

model LanguagePair {
  id              String        @id @default(cuid())
  slug            String        @unique
  sourceLanguageId String
  targetLanguageId String
  label           String
  description     String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sourceLanguage  Language      @relation("SourceLanguage", fields: [sourceLanguageId], references: [id], onDelete: Restrict)
  targetLanguage  Language      @relation("TargetLanguage", fields: [targetLanguageId], references: [id], onDelete: Restrict)
  courses         Course[]
  dailyGoals      DailyGoal[]
  userProgress    UserProgress[]
  reviewHistory   ReviewHistory[]

  @@unique([sourceLanguageId, targetLanguageId])
  @@map("language_pairs")
}

model Course {
  id             String         @id @default(cuid())
  slug           String         @unique
  languagePairId String
  title          String
  description    String?        @db.Text
  levelLabel     String?
  status         CourseStatus   @default(DRAFT)
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  languagePair   LanguagePair   @relation(fields: [languagePairId], references: [id], onDelete: Cascade)
  units          Unit[]
  scenarios      Scenario[]
  userProgress   UserProgress[]

  @@map("courses")
}

model Unit {
  id          String    @id @default(cuid())
  courseId    String
  slug        String
  title       String
  description String?   @db.Text
  sortOrder   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  @@unique([courseId, slug])
  @@map("units")
}

model Lesson {
  id                  String          @id @default(cuid())
  unitId              String
  slug                String
  title               String
  description         String?         @db.Text
  estimatedMinutes    Int?
  scenarioId          String?
  learningObjectives  Json?
  learnSteps          Json?
  sortOrder           Int
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  unit                Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  scenario            Scenario?       @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  exercises           Exercise[]
  vocabularyItems     VocabularyItem[]
  grammarNotes        GrammarNote[]
  userProgress        UserProgress[]
  reviewHistory       ReviewHistory[]

  @@unique([unitId, slug])
  @@map("lessons")
}

model Exercise {
  id              String        @id @default(cuid())
  lessonId        String
  slug            String
  type            ExerciseType
  prompt          String        @db.Text
  instructions    String?       @db.Text
  content         Json
  explanation     String?       @db.Text
  audioUrl        String?
  sortOrder       Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lesson          Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  options         ExerciseOption[]
  reviewHistory   ReviewHistory[]

  @@unique([lessonId, slug])
  @@map("exercises")
}

model ExerciseOption {
  id          String    @id @default(cuid())
  exerciseId  String
  label       String
  value       String
  explanation String?   @db.Text
  isCorrect   Boolean   @default(false)
  sortOrder   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@map("exercise_options")
}

model VocabularyItem {
  id               String    @id @default(cuid())
  lessonId         String?
  languageId       String
  term             String
  transliteration  String?
  translation      String
  usageNote        String?   @db.Text
  exampleText      String?   @db.Text
  exampleTranslation String? @db.Text
  proficiencyLabel String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lesson           Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  language         Language  @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@map("vocabulary_items")
}

model GrammarNote {
  id          String   @id @default(cuid())
  lessonId    String?
  languageId  String
  title       String
  summary     String   @db.Text
  examples    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lesson      Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@map("grammar_notes")
}

model Scenario {
  id                String         @id @default(cuid())
  courseId          String
  languageId        String
  slug              String         @unique
  title             String
  summary           String?        @db.Text
  culturalContext   String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  course            Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  language          Language       @relation(fields: [languageId], references: [id], onDelete: Cascade)
  lessons           Lesson[]
  steps             ScenarioStep[]

  @@map("scenarios")
}

model ScenarioStep {
  id          String    @id @default(cuid())
  scenarioId  String
  title       String
  narrative   String    @db.Text
  stepType    ScenarioStepType @default(CONTEXT)
  sortOrder   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  scenario    Scenario  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("scenario_steps")
}

model UserProgress {
  id                String             @id @default(cuid())
  userId            String
  languagePairId    String
  courseId          String
  lessonId          String?
  status            ProgressStatus     @default(NOT_STARTED)
  completionPercent Int                @default(0)
  accuracy          Decimal?           @db.Decimal(5, 2)
  timeSpentSeconds  Int                @default(0)
  streakCount       Int                @default(0)
  lastActivityAt    DateTime?
  completedAt       DateTime?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  languagePair      LanguagePair       @relation(fields: [languagePairId], references: [id], onDelete: Cascade)
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson            Lesson?            @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([userId, lastActivityAt])
  @@unique([userId, courseId, lessonId])
  @@map("user_progress")
}

model ReviewHistory {
  id               String       @id @default(cuid())
  userId           String
  languagePairId   String
  lessonId         String?
  exerciseId       String?
  result           ReviewResult
  accuracy         Decimal?     @db.Decimal(5, 2)
  responseTimeMs   Int?
  reviewedAt       DateTime     @default(now())
  notes            String?      @db.Text
  metadata         Json?
  languagePair     LanguagePair @relation(fields: [languagePairId], references: [id], onDelete: Cascade)
  lesson           Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  exercise         Exercise?    @relation(fields: [exerciseId], references: [id], onDelete: SetNull)

  @@index([userId, reviewedAt])
  @@map("review_history")
}

model DailyGoal {
  id               String       @id @default(cuid())
  userId           String
  languagePairId   String
  targetMinutes    Int
  targetLessons    Int?
  targetAccuracy   Decimal?     @db.Decimal(5, 2)
  currentMinutes   Int          @default(0)
  completedLessons Int          @default(0)
  streakCount      Int          @default(0)
  goalDate         DateTime
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  languagePair     LanguagePair @relation(fields: [languagePairId], references: [id], onDelete: Cascade)

  @@unique([userId, languagePairId, goalDate])
  @@map("daily_goals")
}

enum MessageStatus {
  NEW
  IN_PROGRESS
  DONE
}

enum LanguageDirection {
  LTR
  RTL
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExerciseType {
  MULTIPLE_CHOICE
  SENTENCE_ORDERING
  FILL_IN_THE_BLANK
  WRITE_TRANSLATION
  DIALOGUE_COMPLETION
  LISTENING_COMPREHENSION
}

enum ScenarioStepType {
  CONTEXT
  DIALOGUE
  CULTURE
  TASK
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ReviewResult {
  CORRECT
  INCORRECT
  PARTIAL
  SKIPPED
}
